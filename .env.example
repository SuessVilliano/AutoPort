# ─────────────────────────────────────────────────────────
#  AUTOPORT — Marketplace Edition
#  Copy this file to .env for local dev.
#  In Vercel: add these in Project Settings → Environment Variables
#
#  NOTE: Twilio credentials are provided by each user
#  via the frontend — they are NOT stored server-side.
# ─────────────────────────────────────────────────────────

# ── EMAIL PROVIDER (choose one) ───────────────────────────
# Option A: SendGrid (recommended)
# Sign up: sendgrid.com → Settings → API Keys → Create Key
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx

# Option B: Resend (simpler, great free tier — resend.com)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# From email address (must be verified in SendGrid/Resend)
FROM_EMAIL=noreply@autoport.app

# ── AI CHAT ASSISTANT (choose one) ────────────────────────
# Powers the customer-facing porting assistant chat.
# If neither is set, the chat uses curated static responses.

# Option A: Google Gemini (free tier available — ai.google.dev)
# GEMINI_API_KEY=your_gemini_key_here

# Option B: OpenAI (fallback)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# ── OPTIONAL ──────────────────────────────────────────────
# Base URL of this deployment (set automatically by Vercel)
# BASE_URL=https://autoport.vercel.app

# GHL webhook base URL for post-port number configuration
# GHL_WEBHOOK_BASE=https://services.leadconnectorhq.com
