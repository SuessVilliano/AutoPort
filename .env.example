# ─────────────────────────────────────────────────────────
#  AUTOPORT — Environment Variables
#  Copy this file to .env for local dev.
#  In Vercel: add these in Project Settings → Environment Variables
# ─────────────────────────────────────────────────────────

# ── TWILIO MASTER ACCOUNT ─────────────────────────────────
# Your GHL master Twilio Account SID (starts with AC)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your GHL master Twilio Auth Token
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your webhook signing secret (from Twilio Console → Webhooks)
TWILIO_WEBHOOK_SECRET=your_webhook_secret_here

# ── GHL INTERNAL ──────────────────────────────────────────
# GHL internal API key for looking up location→subaccount mappings
GHL_API_KEY=your_ghl_api_key_here

# ── EMAIL PROVIDER (choose one) ───────────────────────────
# Option A: SendGrid (recommended — Twilio's own email product)
# Sign up: sendgrid.com → Settings → API Keys → Create Key (Full Access)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxx

# Option B: Resend (simpler, great free tier — resend.com)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# From email address (must be verified in SendGrid/Resend)
FROM_EMAIL=autoport@gohighlevel.com

# ── NOTIFICATIONS ─────────────────────────────────────────
# Auto-CC on ALL port request emails — always included, cannot be overridden
INTERNAL_CC_EMAIL=migration@leadconnectorhq.com

# ── OPTIONAL ──────────────────────────────────────────────
# Base URL of this deployment (set automatically by Vercel)
# BASE_URL=https://autoport.vercel.app
